app.post('/api/posts', IsAuthenticatedMiddleware(), async (req, res) => {
    let db = await get_db();
    let col = db.collection('users')
    let username = req.body.username || res.locals.username

    let result = await col.findOne({
        username
    })

    if (result == null  || username === 'admin') {
        return res.status(404).send()
    }

    col = db.collection('posts');

    result = await col.find(query = {
        username
    }
    ).toArray()

    return res.status(200).json(result)
})

