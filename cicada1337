# Estrazione numeri primi dai metadati dell'immagine
try:
    command = ["identify", "-verbose", image_path]
    output = subprocess.run(command, capture_output=True, text=True).stdout
    
    # Trova tutti i numeri nell'output di identify
    all_numbers = re.findall(r'\b\d+\b', output)
    
    primes = []
    for n in all_numbers:
        num_val = int(n)
        if is_prime(num_val) and num_val not in primes:
            primes.append(num_val)
    
    # Prende i primi 3 numeri primi trovati
    selected_primes = primes[:3]
    subreddit_id = 1
    for p in selected_primes:
        subreddit_id *= p

    print(f"Numeri primi trovati: {selected_primes}")
    print(f"ID Subreddit (Moltiplicazione): {subreddit_id}")
